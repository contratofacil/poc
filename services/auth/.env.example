# --- Express ---
PORT=3000

# --- Auth ---
JWT_SECRET=your_jwt_secret_here

# --- Database ---
# When DATABASE_URL is set, PostgreSQL is used. Otherwise SQLite (POC) at services/auth/database.sqlite.
DATABASE_URL=postgresql://postgres:password@localhost:5432/easylaw

# --- Email (verification + alerts) ---
SENDGRID_API_KEY=your_sendgrid_key_here

# ---------------------------------------------------------------------------
# Story 6-3 — Vault (Cloudflare R2 + envelope encryption)
# ---------------------------------------------------------------------------
# Driver selects the storage backend:
#   r2     = production target. Requires ALL R2_* vars + VAULT_KEK_B64.
#   local  = in-memory POC fallback. Files live in the Node process; gone on restart.
#            Encryption still happens IF VAULT_KEK_B64 is set, useful for testing
#            round-trips without R2 credentials.
# In production (NODE_ENV=production) the driver defaults to 'r2' and the service
# refuses to start if any R2 var or the KEK is missing/invalid.
VAULT_DRIVER=local

# Cloudflare R2 — bucket must be created in EU jurisdiction:
# Cloudflare dashboard → R2 → Create bucket → Location: EU (jurisdiction)
R2_ACCOUNT_ID=
R2_ACCESS_KEY_ID=
R2_SECRET_ACCESS_KEY=
R2_BUCKET=easylaw-vault-prod
# Optional — defaults to the EU jurisdiction endpoint computed from R2_ACCOUNT_ID:
#   https://${R2_ACCOUNT_ID}.eu.r2.cloudflarestorage.com
# Set explicitly only for staging buckets or alternative juridictions.
R2_ENDPOINT=

# Master Key Encryption Key (AES-256, base64-encoded, must decode to exactly 32 bytes).
# Generate once with:    openssl rand -base64 32
# Or in Node:            node -e "console.log(require('crypto').randomBytes(32).toString('base64'))"
# This wraps the per-file DEK in vault_documents.encrypted_dek. Losing it makes
# every encrypted document UNRECOVERABLE — back it up to a secret manager.
VAULT_KEK_B64=
